// prisma/schema.prisma

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma" // Required: you must now specify an output path
  moduleFormat = "cjs"                      // Vital for your CommonJS project
  engineType   = "binary"
}


datasource db {
  provider = "mysql"  
  relationMode = "prisma"
}
