// prisma/schema/userPermission.prisma

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entityId String
  entity    Entity @relation(fields: [entityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // CRUD flags
  canCreate  Boolean  @default(false)
  canRead    Boolean  @default(false)
  canUpdate  Boolean  @default(false)
  canDelete  Boolean  @default(false)
  
  // Row-level scope
  scope      PermissionScope @default(ALL)
  
  // Permission type (CRUD, PROCESS, READ_ONLY)
  permissionType PermissionType @default(CRUD)
  
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deletedByUserId String?
  deletedByUser User? @relation("deleted_user_permissions", fields: [deletedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  deletedAt  DateTime? @db.Timestamp(0)

  @@unique([userId, entityId])
  @@index([userId, deletedAt])
  @@index([entityId])
  @@index([deletedByUserId])
  @@map("user_permissions")
}

enum PermissionScope {
  NONE // No access
  OWN  // Only records created by this user
  ALL  // All records in the table
}